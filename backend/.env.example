PORT=3000
JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@xplore.local
ADMIN_PASSWORD=admin123

# Postgres connection string from your Supabase project
# Settings -> Database -> Connection string -> URI (use the "Transaction" pooler on port 6543)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].pooler.supabase.com:6543/postgres

# Supabase project URL and service_role key (Settings -> API)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_BUCKET=product-photos
